{
  "algorithm": "crc32",
  "source": "RFC 1952 (gzip), IEEE 802.3 / zlib CRC-32. Polynomial 0xedb88320 (reflected).",
  "notes": "Initial value 0xFFFFFFFF, final XOR 0xFFFFFFFF. All test vectors independently verified via Python zlib.crc32.",
  "vectors": [
    {
      "name": "empty",
      "input_hex": "",
      "expected_hex": "00000000",
      "description": "CRC-32 of empty input."
    },
    {
      "name": "single_byte_a",
      "input_hex": "61",
      "expected_hex": "e8b7be43",
      "description": "CRC-32('a')."
    },
    {
      "name": "abc",
      "input_hex": "616263",
      "expected_hex": "352441c2",
      "description": "CRC-32('abc')."
    },
    {
      "name": "check_123456789",
      "input_hex": "313233343536373839",
      "expected_hex": "cbf43926",
      "description": "CRC-32('123456789') — the classic 'check' value across CRC-32 implementations."
    },
    {
      "name": "message_digest",
      "input_hex": "6d65737361676520646967657374",
      "expected_hex": "20159d7f",
      "description": "CRC-32('message digest')."
    },
    {
      "name": "alphabet_lower",
      "input_hex": "6162636465666768696a6b6c6d6e6f707172737475767778797a",
      "expected_hex": "4c2750bd",
      "description": "CRC-32('abcdefghijklmnopqrstuvwxyz')."
    },
    {
      "name": "quick_brown_fox",
      "input_hex": "54686520717569636b2062726f776e20666f78206a756d7073206f76657220746865206c617a7920646f67",
      "expected_hex": "414fa339",
      "description": "CRC-32('The quick brown fox jumps over the lazy dog')."
    },
    {
      "name": "Wikipedia",
      "input_hex": "57696b697065646961",
      "expected_hex": "adaac02e",
      "description": "CRC-32('Wikipedia')."
    }
  ]
}
